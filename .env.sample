# ============================================================
# AfrozonAuto Backend — Environment Variables Sample
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.
# ============================================================

# ─── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                    # development | production | staging
APP_SECRET=your_app_secret_here
PUBLIC_URL=http://localhost:3000
APP_URL=http://localhost:3000
FRONT_END_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=afrozonauto

# ─── Auth / JWT ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_32_chars
EXPIRES_IN_SHORT=15m                    # Access token lifetime
EXPIRES_IN_LONG=7d                      # Refresh token lifetime

# ─── Cookies ────────────────────────────────────────────────
COOKIE_SECURE=false                     # true in production (HTTPS only)
COOKIE_SAMESITE=lax                     # strict | lax | none
COOKIE_DOMAIN=localhost
ACCESS_TOKEN_COOKIE_NAME=access_token
ACCESS_TOKEN_MAX_AGE=900000             # 15 minutes in ms
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_MAX_AGE=604800000         # 7 days in ms
REFRESH_TOKEN_PATH=/api/auth/refresh-token

# ─── OTP / Token ────────────────────────────────────────────
TOKEN_EXPIRY_MINUTES=5                  # OTP expiry in minutes (default: 5)

# ─── Email — SMTP (Nodemailer) ──────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@example.com

# ─── Email — Resend ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_EMAIL=noreply@example.com
SEND_MAIL_API_KEY=your_sendmail_api_key
SEND_MAIL_SMS_PHONE=+2348000000000

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=afrozonauto

# ─── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_LOGIN_FAILURE_REDIRECT=http://localhost:5173/auth/error
GOOGLE_PROFILE=https://www.googleapis.com/auth/userinfo.profile

# ─── Apple Sign-In ──────────────────────────────────────────
APPLE_CLIENT_ID=com.example.afrozonauto
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_IDENTIFIER=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_REDIRECT_URI=http://localhost:3000/api/auth/apple/callback

# ─── Paystack ───────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET_KEY=your_paystack_webhook_secret

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_LINK=https://buy.stripe.com/test_xxxxxxxx

# ─── Flutterwave ────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_HASH=your_flutterwave_secret_hash

# ─── Redis / Upstash ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_HOURS=12               # Default: 12
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── Encryption ─────────────────────────────────────────────
ENCRYPTION_ALGO=aes-256-cbc
ENCRYPTION_SECRET=your_32_char_encryption_secret_here

# ─── Vehicle Data API (Auto.dev) ───────────────────────────
AUTO_DEV_API_KEY=your_auto_dev_api_key
AUTO_DEV_BASE_URL=https://api.auto.dev

# ─── Exchange Rates ─────────────────────────────────────────
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD
EXCHANGE_RATE_CACHE_TTL=3600           # Seconds to cache exchange rates

# ─── Business Logic ─────────────────────────────────────────
DEPOSIT_PERCENTAGE=0.3                 # 30% deposit of total vehicle price
ADMIN_DASH=http://localhost:5173/admin
